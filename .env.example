# Telegram client API (NOT BotFather). Get from https://my.telegram.org
TG_API_ID=123456
TG_API_HASH=abcdef0123456789abcdef0123456789

# Telethon session file name (created on first login)
TG_SESSION=reader_session
# Optional split sessions (recommended to avoid SQLite lock between collector and sender)
# TG_SESSION_COLLECTOR=reader_collector
# TG_SESSION_SENDER=reader_sender

# Comma-separated channel usernames (without @) where READER is already a member
# Example: TG_CHANNELS=whale_alert,defi_updates,airdrop_alpha
# Or set TG_CHANNELS=ALL to collect from all subscribed public channels.
TG_CHANNELS=channel1,channel2,channel3

# SQLite database path
DB_PATH=/home/gpt/tg-web3-digest/tg_digest.sqlite3

# Collector interval (seconds): 600=10m, 900=15m, 3600=1h
POLL_SECONDS=3600

# Where to send digest:
# Exact name of your private group that includes BOTH: your main + Reader
TG_TARGET=Web3 Digest

# Digest size limits
MAX_ITEMS=12
MAX_CHARS_PER_ITEM=220
