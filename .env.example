# Telegram client API (NOT BotFather). Get from https://my.telegram.org
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash

# StringSession (generate via: python -c "from telethon.sync import TelegramClient; from telethon.sessions import StringSession; c=TelegramClient(StringSession(),'API_ID','API_HASH'); c.start(); print(c.session.save())")
TG_SESSION_STRING=your_string_session

# Comma-separated channels or ALL
TG_CHANNELS=ALL

# Where to send digest (exact chat/group name or @username)
TG_TARGET=Digest_mi

# SQLite DB path (use /data/... with Railway Volume)
DB_PATH=/data/tg_digest.sqlite3

# Collector poll interval (seconds)
POLL_SECONDS=3600

# Digest send hours (comma-separated, local TZ)
SEND_HOURS=8,11,14,19
TZ_DIGEST=Asia/Jerusalem

# Digest size
MAX_ITEMS=12
MAX_CHARS_PER_ITEM=220
